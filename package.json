{
  "name": "redis-scanner",
  "version": "0.1.0",
  "description": "Redis Discovery — discovers and inventories Redis-compatible databases on authorized networks",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "rscan": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-web-assets.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src test",
    "format": "prettier --write src test",
    "format:check": "prettier --check src test",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "htmx.org": "^2.0.10",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "express": "^4.19.0",
    "ioredis": "^5.0.0"
  }
}
